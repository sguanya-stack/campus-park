{
  "openapi": "3.1.0",
  "info": {
    "title": "CampusPark API",
    "version": "1.0.0",
    "description": "REST API for the CampusPark campus parking reservation system.\n\n**Auth**: Most mutating endpoints require a Bearer token obtained from `/api/auth/login`.\n\n**Rate limits**: Responses include `X-RateLimit-Limit`, `X-RateLimit-Remaining`, and `X-RateLimit-Reset` headers.\n\n**Idempotency**: Include an `Idempotency-Key` header on `POST /api/bookings` to safely retry without double-booking.\n\n**Correlation IDs**: Every response includes `X-Request-ID` for log tracing."
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Local dev server" }
  ],
  "security": [],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "JWT-style opaque token returned by `/api/auth/login`"
      }
    },
    "schemas": {
      "ParkingSpot": {
        "type": "object",
        "properties": {
          "id":             { "type": "string" },
          "name":           { "type": "string" },
          "zone":           { "type": "string" },
          "totalSpots":     { "type": "integer" },
          "availableSpots": { "type": "integer" },
          "pricePerHour":   { "type": "number" },
          "lat":            { "type": "number" },
          "lng":            { "type": "number" },
          "status":         { "type": "string", "enum": ["active", "inactive"] },
          "features":       { "type": "array", "items": { "type": "string" } },
          "surgeMultiplier":{ "type": "number", "description": "1.0–2.0× surge pricing factor" },
          "predictedAvail": { "type": "integer", "description": "Predicted available spots in 1 hour" }
        }
      },
      "Booking": {
        "type": "object",
        "properties": {
          "id":          { "type": "string" },
          "spotId":      { "type": "string" },
          "spotName":    { "type": "string" },
          "plate":       { "type": "string" },
          "phone":       { "type": "string" },
          "startTime":   { "type": "string", "format": "date-time" },
          "endTime":     { "type": "string", "format": "date-time" },
          "status":      { "type": "string", "enum": ["PENDING", "ACTIVE", "COMPLETED", "CANCELLED", "EXPIRED"] },
          "totalCost":   { "type": "number" },
          "createdAt":   { "type": "string", "format": "date-time" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error":     { "type": "string" },
          "requestId": { "type": "string" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid auth token",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "RateLimit": {
        "description": "Too many requests",
        "headers": {
          "Retry-After": { "schema": { "type": "integer" }, "description": "Seconds to wait before retrying" }
        },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new student account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "password"],
                "properties": {
                  "name":     { "type": "string", "minLength": 2, "maxLength": 20 },
                  "password": { "type": "string", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Account created", "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" } } } } } },
          "409": { "description": "Username already taken" },
          "429": { "$ref": "#/components/responses/RateLimit" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login and obtain a bearer token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "password"],
                "properties": {
                  "name":     { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "user":  {
                      "type": "object",
                      "properties": {
                        "id":   { "type": "string" },
                        "name": { "type": "string" },
                        "role": { "type": "string", "enum": ["student", "admin"] }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials" },
          "429": { "$ref": "#/components/responses/RateLimit" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Invalidate the current session token",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/spots": {
      "get": {
        "tags": ["Spots"],
        "summary": "List parking spots with optional filters",
        "parameters": [
          { "name": "zone",   "in": "query", "schema": { "type": "string" }, "description": "Filter by zone name" },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Fuzzy search by name or features" },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["price", "available", "distance"] } },
          { "name": "lat",    "in": "query", "schema": { "type": "number" }, "description": "User latitude (for distance sort)" },
          { "name": "lng",    "in": "query", "schema": { "type": "number" }, "description": "User longitude (for distance sort)" }
        ],
        "responses": {
          "200": {
            "description": "Array of parking spots",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ParkingSpot" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Spots"],
        "summary": "Create a new parking spot (admin only)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "zone", "totalSpots", "pricePerHour"],
                "properties": {
                  "name":         { "type": "string" },
                  "zone":         { "type": "string" },
                  "totalSpots":   { "type": "integer", "minimum": 1 },
                  "pricePerHour": { "type": "number", "minimum": 0 },
                  "lat":          { "type": "number" },
                  "lng":          { "type": "number" },
                  "features":     { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Spot created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParkingSpot" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "description": "Admin role required" }
        }
      }
    },
    "/api/spots/stream": {
      "get": {
        "tags": ["Spots"],
        "summary": "SSE stream of real-time spot availability updates",
        "description": "Server-Sent Events endpoint. Each event is a JSON array of all spots. Reconnects automatically via EventSource.",
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/spots/{id}/rate": {
      "post": {
        "tags": ["Spots"],
        "summary": "Submit a star rating for a spot after checkout",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reservationId", "stars"],
                "properties": {
                  "reservationId": { "type": "string" },
                  "stars":         { "type": "integer", "minimum": 1, "maximum": 5 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Rating saved" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/spots/{id}/rating": {
      "get": {
        "tags": ["Spots"],
        "summary": "Get average star rating for a spot",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Average rating",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "average": { "type": "number" },
                    "count":   { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/recommend": {
      "get": {
        "tags": ["Spots"],
        "summary": "AI-powered spot recommendation",
        "parameters": [
          { "name": "zone",   "in": "query", "schema": { "type": "string" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "lat",    "in": "query", "schema": { "type": "number" } },
          { "name": "lng",    "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "Recommended spot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "spot":   { "$ref": "#/components/schemas/ParkingSpot" },
                    "reason": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/bookings": {
      "post": {
        "tags": ["Bookings"],
        "summary": "Create a new reservation",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "schema": { "type": "string", "format": "uuid" },
            "description": "Provide a unique UUID to safely retry without creating duplicate reservations"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["spotId", "plate", "phone", "startTime", "durationHours"],
                "properties": {
                  "spotId":        { "type": "string" },
                  "plate":         { "type": "string", "pattern": "^[A-Z0-9 -]{2,10}$" },
                  "phone":         { "type": "string" },
                  "startTime":     { "type": "string", "format": "date-time" },
                  "durationHours": { "type": "number", "minimum": 0.5, "maximum": 24 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Reservation created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Booking" } } } },
          "400": { "description": "Validation error or no spots available" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimit" }
        }
      }
    },
    "/api/bookings/me": {
      "get": {
        "tags": ["Bookings"],
        "summary": "List reservations for the authenticated user",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "User's booking history",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Booking" } }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/bookings/me/export": {
      "get": {
        "tags": ["Bookings"],
        "summary": "Download user's booking history as JSON",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "JSON file download",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Booking" } } } }
          }
        }
      }
    },
    "/api/bookings/{id}": {
      "delete": {
        "tags": ["Bookings"],
        "summary": "Cancel a pending reservation",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Reservation cancelled" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "description": "Not your reservation" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/check-in": {
      "post": {
        "tags": ["Bookings"],
        "summary": "Check in to activate a PENDING reservation",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["reservationId"], "properties": { "reservationId": { "type": "string" } } }
            }
          }
        },
        "responses": {
          "200": { "description": "Checked in", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Booking" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/check-out": {
      "post": {
        "tags": ["Bookings"],
        "summary": "Check out to complete an ACTIVE reservation",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["reservationId"], "properties": { "reservationId": { "type": "string" } } }
            }
          }
        },
        "responses": {
          "200": { "description": "Checked out, spot released", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Booking" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/stats": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Aggregate statistics for all spots",
        "responses": {
          "200": {
            "description": "Platform-wide stats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalSpots":     { "type": "integer" },
                    "totalAvailable": { "type": "integer" },
                    "activeBookings": { "type": "integer" },
                    "zones":          { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/analytics/heatmap": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Heatmap data — demand intensity per spot",
        "responses": {
          "200": {
            "description": "Array of heatmap points",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "lat":       { "type": "number" },
                      "lng":       { "type": "number" },
                      "intensity": { "type": "number", "description": "0–1 demand intensity" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/analytics": {
      "get": {
        "tags": ["Admin"],
        "summary": "Revenue and booking analytics for the admin dashboard",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Admin analytics data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dailyRevenue":    { "type": "array", "items": { "type": "object" } },
                    "spotUtilization": { "type": "array", "items": { "type": "object" } },
                    "todayRevenue":    { "type": "number" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "description": "Admin role required" }
        }
      }
    }
  }
}

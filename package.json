    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.4",
    "leaflet": "^1.9.4",
    "node-cron": "^4.2.1",
    "prisma": "^5.22.0",
    "react-leaflet": "^5.0.0"
  }
}

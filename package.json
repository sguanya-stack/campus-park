{
  "name": "campus-park-app",
  "version": "1.0.0",
  "private": true,
  "description": "Campus parking app with Node.js backend",
  "scripts": {
    "seed": "node seed.js",
    "prestart": "node scripts/kill-port.js",
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first node server.js",

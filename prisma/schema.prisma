generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum ReservationStatus {
  PENDING
  ACTIVE
  COMPLETED
  CONFIRMED
  CANCELLED
  EXPIRED
}

model AppUser {
  id           String       @id @default(cuid())
  name         String       @unique
  role         String       @default("student")
  passwordSalt String
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sessions     AppSession[]

  @@index([role])
}

model AppSession {
  token     String   @id
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ParkingSpot {
  id                  String        @id @default(cuid())
  externalLocationId  String?       @unique
  slug                String?       @unique
  name                String
  address             String?
  zone                String?
  totalSpots          Int           @default(0)
  availableSpots      Int           @default(0)
  pricePerHour        Decimal?      @db.Decimal(10, 2)
  priceText           String?
  isEV                Boolean       @default(false)
  status              String        @default("active")
  requiresPrintPass   Boolean       @default(false)
  requiresDisplayPass Boolean       @default(false)
  cancellationNotice  Int           @default(0)
  fetchedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  reservations        Reservation[]
  ratings             SpotRating[]

  @@index([zone])
  @@index([status])
  @@index([availableSpots])
}

model Reservation {
  id          String            @id @default(cuid())
  userId      String            // 配合 Supabase Auth 的 UUID
  spotId      String
  startTime   DateTime
  endTime     DateTime
  plateNumber String?
  phoneNumber String?
  ticketCode  String?           @unique @db.VarChar(6)
  checkInTime DateTime?
  checkOutTime DateTime?
  finalAmount Decimal?          @db.Decimal(10, 2)
  status      ReservationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  spot        ParkingSpot       @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spotId])
  @@index([status])
  @@index([ticketCode])
  @@index([checkInTime])
  @@index([checkOutTime])
  @@index([startTime, endTime])
}

model SearchLog {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model SpotRating {
  id            String      @id @default(cuid())
  spotId        String
  userId        String
  reservationId String      @unique
  stars         Int         // 1-5
  createdAt     DateTime    @default(now())

  spot          ParkingSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@unique([userId, spotId])
  @@index([spotId])
}

// Feature flags — admin-toggleable feature switches
model FeatureFlag {
  key         String   @id       // e.g. "surge_pricing", "demand_prediction"
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}

// Funnel analytics — lightweight event store for conversion tracking
// Events: search | spot_view | reserve_start | reserve_complete | check_in | check_out
model FunnelEvent {
  id        String   @id @default(cuid())
  sessionId String   // anonymous browser session UUID (not auth token)
  userId    String?  // set when user is authenticated
  event     String   // funnel step name
  spotId    String?  // optional spot context
  meta      Json?    // arbitrary extra data (search query, duration, etc.)
  createdAt DateTime @default(now())

  @@index([event])
  @@index([sessionId])
  @@index([createdAt])
}
